    "import pandas as pd\n",
    "import requests\n",
    "from io import StringIO\n",
    "\n",
    "response = requests.get(\"http://localhost:8080/bank-statement/generateCsv?pan=ABCD1234A&accountId=ac001\")\n",
    "\n",
    "csv_data = StringIO(response.text)\n",
    "\n",
    "df = pd.read_csv(csv_data)\n",
    "\n",
    "df"
